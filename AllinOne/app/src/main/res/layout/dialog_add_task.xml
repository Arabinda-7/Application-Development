<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <!-- Header: Color Preview -->
    <View
        android:id="@+id/task_color_preview"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:background="@drawable/circle_selected_bg"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="400dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_actions_row">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/task_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="Task Name"
                android:textColor="@color/white"
                android:textColorHint="@color/text_secondary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:inputType="textCapSentences" />

            <TextView
                android:id="@+id/tv_priority_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="PRIORITY"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_priority"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/rb_priority_low"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/circle_selected_bg"
                    android:backgroundTint="@color/primary_blue"
                    android:button="@null"
                    android:layout_marginEnd="12dp"
                    android:alpha="0.3" />
                <RadioButton
                    android:id="@+id/rb_priority_medium"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/circle_selected_bg"
                    android:backgroundTint="@color/card_orange"
                    android:button="@null"
                    android:layout_marginEnd="12dp"
                    android:alpha="0.3" />
                <RadioButton
                    android:id="@+id/rb_priority_high"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/circle_selected_bg"
                    android:backgroundTint="#FF5252"
                    android:button="@null"
                    android:alpha="0.3" />
            </RadioGroup>

            <TextView
                android:id="@+id/tv_category_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="CATEGORY"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:backgroundTint="@color/white" />

            <View
                android:id="@+id/divider_add_task"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#1AFFFFFF" />

            <TextView
                android:id="@+id/tv_subtasks_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="SUBTASKS"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/container_subtasks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:id="@+id/container_add_subtask"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/et_new_subtask"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Add a subtask..."
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp"
                    android:inputType="textCapSentences" />
                <ImageButton
                    android:id="@+id/btn_add_subtask"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_input_add"
                    app:tint="@color/white" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Footer Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_actions_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btn_set_reminder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_rounded"
            android:backgroundTint="#20FFFFFF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_lock_idle_alarm"
                app:tint="@color/white"
                android:contentDescription="Reminder" />

            <TextView
                android:id="@+id/tv_reminder_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Set reminder"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_save_task"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Done"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
