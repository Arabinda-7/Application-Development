<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btn_back_workout_days"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_revert"
        android:rotation="180"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/tv_title_workout_days"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Workout days"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_back_workout_days"
        app:layout_constraintStart_toEndOf="@id/btn_back_workout_days"
        app:layout_constraintTop_toTopOf="@id/btn_back_workout_days" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title_workout_days">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Specific Days in Week -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_specific_days_workout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#333A42"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Specific days in week"
                            android:textColor="@color/white"
                            android:textStyle="bold" />
                        <ImageView
                            android:id="@+id/iv_check_specific_workout"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:src="@android:drawable/checkbox_on_background"
                            app:tint="@color/card_green" />
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tv_specific_days_desc_workout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Everyday"
                        android:textColor="#99FFFFFF"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- S M T W T F S -->
                        <TextView android:id="@+id/day_0_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="S" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_1_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="M" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_2_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="T" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_3_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="W" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_4_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="T" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_5_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="F" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />
                        <TextView android:id="@+id/day_6_workout" android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/circle_selected_bg" android:backgroundTint="@color/chip_selected" android:gravity="center" android:text="S" android:textColor="@color/white" android:textStyle="bold" android:textSize="10sp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- X days per week -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_days_per_week_workout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#333A42"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tv_days_per_week_workout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 day per week"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                    <ImageView
                        android:id="@+id/iv_radio_week_workout"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentEnd="true"
                        android:src="@android:drawable/btn_radio"
                        app:tint="#66FFFFFF" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>