<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btn_close_note"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Back" />

    <TextView
        android:id="@+id/btn_save_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="@id/btn_close_note"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/btn_close_note" />

    <ImageButton
        android:id="@+id/btn_reminder"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:src="@android:drawable/ic_lock_idle_alarm"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/white"
        android:padding="8dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@id/btn_save_note"
        app:layout_constraintEnd_toStartOf="@id/btn_save_note"
        app:layout_constraintTop_toTopOf="@id/btn_save_note"
        android:contentDescription="Set Reminder" />

    <ImageButton
        android:id="@+id/btn_voice_input"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp"
        android:src="@android:drawable/ic_btn_speak_now"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="@color/white"
        android:padding="8dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@id/btn_reminder"
        app:layout_constraintEnd_toStartOf="@id/btn_reminder"
        app:layout_constraintTop_toTopOf="@id/btn_reminder"
        android:contentDescription="Voice Input" />

    <EditText
        android:id="@+id/note_title_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@null"
        android:hint="Title"
        android:textColor="@color/white"
        android:textColorHint="#80FFFFFF"
        android:textSize="32sp"
        android:textStyle="normal"
        android:inputType="textCapSentences"
        app:layout_constraintTop_toBottomOf="@id/btn_close_note" />

    <TextView
        android:id="@+id/tv_note_metadata"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="21 June 7:42 PM | 0 characters"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/note_title_input" />

    <View
        android:id="@+id/note_color_preview"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/circle_selected_bg"
        app:layout_constraintBottom_toBottomOf="@id/tv_note_metadata"
        app:layout_constraintStart_toEndOf="@id/tv_note_metadata"
        app:layout_constraintTop_toTopOf="@id/tv_note_metadata" />

    <EditText
        android:id="@+id/note_content_input"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:background="@null"
        android:hint="Start typing"
        android:textColor="@color/white"
        android:textColorHint="#80FFFFFF"
        android:gravity="top"
        android:inputType="textMultiLine"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_note_metadata" />

</androidx.constraintlayout.widget.ConstraintLayout>
