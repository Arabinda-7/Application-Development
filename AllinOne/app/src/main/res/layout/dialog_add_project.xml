<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_close_project"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <EditText
        android:id="@+id/project_name_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@null"
        android:hint="Project Name"
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:inputType="textCapSentences"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_close_project" />

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#33FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/project_name_input" />

    <EditText
        android:id="@+id/project_desc_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@null"
        android:hint="Project Details / Description..."
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        android:textSize="16sp"
        android:minLines="5"
        android:gravity="top"
        android:inputType="textMultiLine|textCapSentences"
        app:layout_constraintTop_toBottomOf="@id/divider1" />

    <TextView
        android:id="@+id/tv_status_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="STATUS"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/project_desc_input" />

    <RadioGroup
        android:id="@+id/status_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_status_label">
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_working"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:text="Working"
            android:textStyle="bold"
            android:textColor="@color/white" />
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_upcoming"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:gravity="center"
            android:text="Upcoming"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_save_project"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/circle_selected_bg"
        android:backgroundTint="@color/chip_selected"
        android:text="SAVE PROJECT"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/status_radio_group" />

</androidx.constraintlayout.widget.ConstraintLayout>