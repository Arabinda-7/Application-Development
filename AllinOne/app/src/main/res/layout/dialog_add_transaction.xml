<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_close_trans"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="New Transaction"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_close_trans"
        app:layout_constraintStart_toEndOf="@id/btn_close_trans"
        app:layout_constraintTop_toTopOf="@id/btn_close_trans" />

    <EditText
        android:id="@+id/et_trans_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@null"
        android:gravity="center"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_title" />

    <EditText
        android:id="@+id/et_trans_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@null"
        android:hint="Title (e.g. Salary, Grocery)"
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        android:textSize="18sp"
        app:layout_constraintTop_toBottomOf="@id/et_trans_amount" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/et_trans_title" />

    <TextView
        android:id="@+id/tv_type_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="TYPE"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_trans_title" />

    <RadioGroup
        android:id="@+id/rg_trans_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_type_label">
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_expense"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:text="Expense"
            android:textStyle="bold"
            android:textColor="@color/white" />
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_income"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:gravity="center"
            android:text="Income"
            android:textStyle="bold"
            android:textColor="@color/white" />
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_saving"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:gravity="center"
            android:text="Saving"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_save_trans"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/circle_selected_bg"
        android:backgroundTint="@color/chip_selected"
        android:text="SAVE TRANSACTION"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/rg_trans_type" />

</androidx.constraintlayout.widget.ConstraintLayout>