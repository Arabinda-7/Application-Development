<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_close_trans"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="New Transaction"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_close_trans"
        app:layout_constraintStart_toEndOf="@id/btn_close_trans"
        app:layout_constraintTop_toTopOf="@id/btn_close_trans" />

    <EditText
        android:id="@+id/et_trans_amount"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_finance_input"
        android:gravity="center"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:textColor="@color/white"
        android:textColorHint="#40FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_title" />

    <TextView
        android:id="@+id/tv_category_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="CATEGORY"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_trans_amount" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/cg_trans_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="4dp"
        app:layout_constraintTop_toBottomOf="@id/tv_category_label" />

    <EditText
        android:id="@+id/et_trans_custom_category"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_finance_input"
        android:hint="Enter specific reason..."
        android:textColor="@color/white"
        android:textColorHint="#40FFFFFF"
        android:textSize="16sp"
        android:paddingHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/cg_trans_category" />

    <View
        android:id="@+id/divider_trans"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#33FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/et_trans_custom_category" />

    <LinearLayout
        android:id="@+id/container_date_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/divider_trans">

        <TextView
            android:id="@+id/tv_trans_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/filter_chip_bg"
            android:backgroundTint="#1AFFFFFF"
            android:gravity="center"
            android:padding="10dp"
            android:text="Select Date"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_trans_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/filter_chip_bg"
            android:backgroundTint="#1AFFFFFF"
            android:gravity="center"
            android:padding="10dp"
            android:text="Select Time"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_type_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="TYPE"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/container_date_time" />

    <RadioGroup
        android:id="@+id/rg_trans_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/tv_type_label">
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_expense"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:text="Expense"
            android:textStyle="bold"
            android:textColor="@color/white" />
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_income"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:gravity="center"
            android:text="Income"
            android:textStyle="bold"
            android:textColor="@color/white" />
        <androidx.appcompat.widget.AppCompatRadioButton
            android:id="@+id/radio_saving"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/mock_chip_bg_selected"
            android:button="@null"
            android:gravity="center"
            android:text="Saving"
            android:textStyle="bold"
            android:textColor="@color/white" />
    </RadioGroup>

    <TextView
        android:id="@+id/btn_save_trans"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="SAVE"
        android:textColor="#1A73E8"
        android:textSize="16sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rg_trans_type" />

</androidx.constraintlayout.widget.ConstraintLayout>