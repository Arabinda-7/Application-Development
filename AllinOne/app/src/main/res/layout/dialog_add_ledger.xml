<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_close_ledger"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="New Entry"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btn_close_ledger"
        app:layout_constraintStart_toEndOf="@id/btn_close_ledger"
        app:layout_constraintTop_toTopOf="@id/btn_close_ledger" />

    <TextView
        android:id="@+id/btn_save_ledger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SAVE"
        android:textColor="#1A73E8"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintBottom_toBottomOf="@id/tv_dialog_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_dialog_title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constrainedHeight="true"
        app:layout_constraintHeight_max="500dp"
        app:layout_constraintTop_toBottomOf="@id/tv_dialog_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/et_ledger_amount"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:background="@drawable/bg_finance_input"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:hint="0.00"
                android:inputType="numberDecimal"
                android:textColor="@color/white"
                android:textColorHint="#40FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_person_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="PERSON"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_person_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_finance_input"
                android:backgroundTint="#11FFFFFF"
                android:hint="Who are you dealing with?"
                android:textColor="@color/white"
                android:textColorHint="#40FFFFFF"
                android:textSize="16sp"
                android:paddingHorizontal="16dp"
                android:inputType="textPersonName" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="TYPE"
                android:textColor="#80FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_ledger_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <androidx.appcompat.widget.AppCompatRadioButton
                    android:id="@+id/radio_borrowed"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/mock_chip_bg_selected"
                    android:button="@null"
                    android:checked="true"
                    android:gravity="center"
                    android:text="Borrowed"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
                <androidx.appcompat.widget.AppCompatRadioButton
                    android:id="@+id/radio_lent"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:background="@drawable/mock_chip_bg_selected"
                    android:button="@null"
                    android:gravity="center"
                    android:text="Lent"
                    android:textStyle="bold"
                    android:textColor="@color/white" />
            </RadioGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#1AFFFFFF" />

            <TextView
                android:id="@+id/tv_ledger_due_date"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/filter_chip_bg"
                android:backgroundTint="#1AFFFFFF"
                android:gravity="center"
                android:text="Select Due Date"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />

            <EditText
                android:id="@+id/et_ledger_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_finance_input"
                android:backgroundTint="#11FFFFFF"
                android:hint="Any details or notes..."
                android:textColor="@color/white"
                android:textColorHint="#40FFFFFF"
                android:textSize="14sp"
                android:padding="16dp"
                android:minLines="3"
                android:gravity="top" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
