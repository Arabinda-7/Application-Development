<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_background"
    android:padding="20dp">

    <ImageView
        android:id="@+id/btn_close"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="Close"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless" />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/white"
        android:contentDescription="More" />

    <EditText
        android:id="@+id/habit_name_input"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@null"
        android:hint="Habit Name"
        android:textColor="@color/white"
        android:textColorHint="@color/text_secondary"
        android:textSize="22sp"
        android:textStyle="bold"
        android:inputType="textCapSentences"
        app:layout_constraintEnd_toStartOf="@+id/btn_edit_name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_close" />

    <ImageView
        android:id="@+id/btn_edit_name"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_edit"
        app:layout_constraintBottom_toBottomOf="@id/habit_name_input"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/habit_name_input"
        app:tint="@color/text_secondary"
        android:contentDescription="Edit" />

    <TextView
        android:id="@+id/tv_habit_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Regular habit"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/habit_name_input" />

    <!-- Icon Selection Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_habit_icon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/chip_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/tv_habit_type">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">
            <ImageView
                android:id="@+id/icon_preview"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_selected_bg"
                android:backgroundTint="@color/card_blue"
                android:padding="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="16dp"
                android:layout_toEndOf="@id/icon_preview"
                android:text="Icon"
                android:textColor="@color/white" />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_media_next"
                app:tint="@color/text_secondary" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Color Selection Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_habit_color"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/chip_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@id/card_habit_icon">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Color"
                android:textColor="@color/white" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical">
                <View
                    android:id="@+id/color_preview"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/circle_selected_bg"
                    android:backgroundTint="@color/card_blue" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/text_secondary" />
            </LinearLayout>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_repeat_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="REPEAT"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_habit_color" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_repeat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/chip_background"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tv_repeat_label">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Habit days"
                android:textColor="@color/white" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_repeat_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Everyday"
                    android:textColor="@color/white" />
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginStart="8dp"
                    android:src="@android:drawable/ic_media_next"
                    app:tint="@color/text_secondary"
                    android:contentDescription="Change Frequency" />
            </LinearLayout>
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_doit_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="DO IT AT"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_repeat" />

    <RadioGroup
        android:id="@+id/frequency_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/tv_doit_label">
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2">
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_daily"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/mock_chip_bg_selected"
                android:button="@null"
                android:checked="true"
                android:gravity="center"
                android:text="Anytime"
                android:textStyle="bold"
                android:textColor="@color/white" />
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_morning"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/mock_chip_bg_selected"
                android:button="@null"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawablePadding="12dp"
                android:drawableTint="@color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:text="Morning"
                android:textStyle="bold"
                android:textColor="@color/white" />
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_afternoon"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/mock_chip_bg_selected"
                android:button="@null"
                android:drawableStart="@android:drawable/ic_menu_today"
                android:drawablePadding="12dp"
                android:drawableTint="@color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:text="Afternoon"
                android:textStyle="bold"
                android:textColor="@color/white" />
            <androidx.appcompat.widget.AppCompatRadioButton
                android:id="@+id/radio_evening"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_columnWeight="1"
                android:layout_margin="4dp"
                android:background="@drawable/mock_chip_bg_selected"
                android:button="@null"
                android:drawableStart="@android:drawable/ic_menu_month"
                android:drawablePadding="12dp"
                android:drawableTint="@color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="center_vertical"
                android:text="Evening"
                android:textStyle="bold"
                android:textColor="@color/white" />
        </GridLayout>
    </RadioGroup>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/circle_selected_bg"
        android:backgroundTint="@color/chip_selected"
        android:text="SAVE"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/frequency_radio_group" />

</androidx.constraintlayout.widget.ConstraintLayout>