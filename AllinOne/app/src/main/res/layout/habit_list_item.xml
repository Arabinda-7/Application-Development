<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp"
    android:background="@color/dark_background">

    <ImageView
        android:id="@+id/iv_expand_chevron_habit"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginTop="24dp"
        android:src="@android:drawable/ic_menu_more"
        android:rotation="90"
        app:tint="#66FFFFFF"
        android:contentDescription="Expand" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/habit_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/card_blue">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <CheckBox
                    android:id="@+id/habit_completed"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_centerVertical="true"
                    android:button="@android:color/transparent"
                    android:background="@drawable/custom_checkbox_selector" />

                <ImageView
                    android:id="@+id/habit_icon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_toEndOf="@id/habit_completed"
                    android:layout_marginStart="12dp"
                    android:src="@android:drawable/ic_menu_directions"
                    android:padding="8dp"
                    app:tint="@color/white" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toEndOf="@id/habit_icon"
                    android:layout_marginStart="12dp"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/habit_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:text="Habit Name" />

                    <TextView
                        android:id="@+id/habit_frequency"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#CCFFFFFF"
                        android:text="Anytime" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/edit_habit_button"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_more"
                    app:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:id="@+id/expandable_controls_habit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_start_timer_habit"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:cardBackgroundColor="#333A42"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="START TIMER"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>