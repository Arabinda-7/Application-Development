<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".AllInOneApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AllinOne">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".HabitTrackerActivity" />
        <activity android:name=".ToDoListActivity" />
        <activity android:name=".WorkoutRoutineActivity" />
        <activity android:name=".TimerActivity" />
        <activity android:name=".NotesActivity" />
        <activity android:name=".ProjectActivity" />
        <activity android:name=".FinanceActivity" />
        <activity android:name=".FinanceHistoryActivity" />
        <activity android:name=".SettingsActivity" />
        <activity android:name=".HabitDetailActivity" />
        <activity android:name=".WorkoutDetailActivity" />
    </application>

</manifest>
