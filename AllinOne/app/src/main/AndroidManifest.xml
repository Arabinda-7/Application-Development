<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".AllInOneApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AllinOne">

        <receiver android:name=".ReminderReceiver" android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            tools:ignore="MissingClass">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".HabitTrackerActivity"
            tools:ignore="MissingClass" />
        <activity android:name=".ToDoListActivity" />
        <activity android:name=".WorkoutRoutineActivity" />
        <activity android:name=".TimerActivity" />
        <activity android:name=".NotesActivity"
            tools:ignore="MissingClass" />
        <activity android:name=".ProjectActivity" />
        <activity android:name=".FinanceActivity" />
        <activity android:name=".FinanceHistoryActivity" />
        <activity android:name=".SettingsActivity"
            tools:ignore="MissingClass" />
        <activity android:name=".HabitDetailActivity" />
        <activity android:name=".WorkoutDetailActivity"
            tools:ignore="MissingClass" />
    </application>

</manifest>
